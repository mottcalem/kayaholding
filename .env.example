# Gmail / Google Workspace SMTP
# https://support.google.com/a/answer/176600
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# 465 kullanıyorsanız: SMTP_PORT=465 ve SMTP_SECURE=true
SMTP_SECURE=false
# Gönderen hesap (Workspace: ornek@kayaholding.com.tr)
SMTP_USER=
# Google Hesap → Güvenlik → 2 Adımlı Doğrulama → Uygulama şifreleri (16 karakter)
SMTP_PASS=
# Boş bırakılırsa SMTP_USER kullanılır; isteğe bağlı: Kaya Holding <ornek@kayaholding.com.tr>
SMTP_FROM=
# Form bildirimlerinin gideceği adres(ler); virgülle ayırabilirsiniz
SMTP_TO=ugur.dogan@kayaholding.com.tr
